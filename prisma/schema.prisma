generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role          String   @default("user")
  createdAt     DateTime @default(now())

  // Seller specific fields
  storeName     String?
  profileImage  String?
  storeStatus   String   @default("active")

  products  Product[]
  orders    Order[]
  cartItems CartItem[]
  wishlistItems WishlistItem[]
}

model Product {
  id                  Int      @id @default(autoincrement())
  sellerId            Int
  name                String
  description         String
  price               Float
  originalPrice       Float?
  discountPercentage  Int?
  isDealOfDay         Boolean  @default(false)
  category            String
  stock               Int      @default(0)
  image               String
  images              String   // JSON string array
  features            String   // JSON string array
  brand               String?
  soldBy              String?
  rating              Float    @default(0)
  reviews             Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Additional product fields
  sku                 String?
  isActive            Boolean  @default(true)
  quantitySold        Int      @default(0)

  seller              User       @relation(fields: [sellerId], references: [id])
  cartItems           CartItem[]
  orderItems          OrderItem[]
  wishlistItems       WishlistItem[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int?
  sessionId String?
  productId Int
  quantity  Int      @default(1)

  user      User?    @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Order {
  id            Int      @id @default(autoincrement())
  userId        Int?
  total         Float
  name          String
  email         String
  address       String
  city          String
  paymentMethod String   @default("card")
  status        String   @default("confirmed")
  cancelReason  String?
  hiddenBySeller String? // JSON array of seller IDs
  createdAt     DateTime @default(now())

  // Additional order fields
  phone         String?
  paymentStatus String   @default("pending")
  deliveryStatus String  @default("processing")

  user          User?    @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float

  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ResetToken {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  otp       String
  expiry    DateTime
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}
